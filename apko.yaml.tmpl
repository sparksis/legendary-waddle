contents:
  repositories:
    - https://dl-cdn.alpinelinux.org/alpine/${ALPINE_RELEASE}/main
    - https://dl-cdn.alpinelinux.org/alpine/${ALPINE_RELEASE}/community
  keyring:
    - keys/alpine-devel@lists.alpinelinux.org-616ae350.rsa.pub
  packages:
    - tor
    - ca-certificates
    - musl
    - busybox

accounts:
  groups:
    - groupname: tor
      gid: 101
  users:
    - username: tor
      uid: 101
      gid: 101
  run-as: tor

environment:
  TOR_NICKNAME: ApkoRelay
  TOR_BANDWIDTH_RATE: 1 MByte
  TOR_BANDWIDTH_BURST: 2 MByte
  TOR_CONTACT: "operator@example.com"

entrypoint:
  command: /bin/sh -c "/usr/bin/tor --Log \"notice stdout\" --ExitRelay 0 --ORPort 9001 --DataDirectory /var/lib/tor --Nickname $TOR_NICKNAME --BandwidthRate \"$TOR_BANDWIDTH_RATE\" --BandwidthBurst \"$TOR_BANDWIDTH_BURST\" --ContactInfo \"$TOR_CONTACT\""

paths:
  - path: /var/lib/tor
    type: directory
    permissions: 0700
    uid: 101
    gid: 101

archs:
  - x86_64
  - aarch64
